#!/bin/sh
# Smart SSH-login notifier.
# - skips non-interactive sessions (automation: `ssh host cmd` has no PTY)
# - skips trusted sources (LAN + Tailscale CGNAT 100.64.0.0/10)
# - alerts ONLY interactive logins from external IPs, async + time-bounded
if [ -n "$SSH_TTY" ]; then
  CLIENT_IP="${SSH_CONNECTION%% *}"
  case "$CLIENT_IP" in
    10.*|192.168.*|172.1[6-9].*|172.2[0-9].*|172.3[0-1].*|127.*|\
    100.6[4-9].*|100.[7-9][0-9].*|100.1[0-1][0-9].*|100.12[0-7].*)
      : ;;  # trusted home/tailnet -> stay quiet
    *)
      curl -s --max-time 5 \
        -H "Title: SSH login on $(hostname)" \
        -H "Priority: high" \
        -H "Tags: warning" \
        -d "Interactive login from $CLIENT_IP as $(whoami) at $(date "+%F %T %Z")" \
        https://ntfy.sh/homelab-logins >/dev/null 2>&1 &
      ;;
  esac
fi
