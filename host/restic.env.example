# Deploy to /etc/homelab-backup/restic.env  (root-owned, chmod 600).
# Sourced by the backup scripts + systemd units. NEVER commit the real file.

# --- AWS creds for the least-privilege pi_backup IAM user (from `tofu output`) ---
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=us-east-1
AWS_RETRY_MODE=adaptive
AWS_MAX_ATTEMPTS=10

# --- restic repository (Tier 1 GIR bucket from OpenTofu output `gir_bucket`) ---
RESTIC_REPOSITORY=s3:s3.amazonaws.com/<PREFIX>-gir-xxxxxxxx
RESTIC_PASSWORD_FILE=/root/.restic-pass

# --- Tier 2 archive bucket (from OpenTofu output `archive_bucket`) ---
ARCHIVE_BUCKET=<PREFIX>-archive-xxxxxxxx

# --- where docker volumes live (backup scripts read this) ---
DOCKER_VOLUMES=/home/youruser/docker/volumes

# --- ntfy topics (pick your OWN unguessable names — ntfy.sh topics are public) ---
NTFY_BACKUPS_TOPIC=homelab-backups
NTFY_HEALTH_TOPIC=homelab-health
