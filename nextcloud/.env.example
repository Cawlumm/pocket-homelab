# Nextcloud. Copy to .env and fill in. Passwords must match the postgres stack.

# --- Database (the shared `postgres` container on the `backend` network) ---
POSTGRES_HOST=postgres
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=CHANGE_ME_match_postgres_stack

# --- Redis / valkey (file locking + cache; see docs/lessons-learned.md) ---
REDIS_HOST=nextcloud-redis

# --- First-run admin account ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_strong_random

# --- Reverse proxy / Cloudflare Tunnel ---
# Space-separated. Include your public host + LAN IP.
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.example.com 192.168.1.10
OVERWRITEPROTOCOL=https
TRUSTED_PROXIES=172.16.0.0/12
