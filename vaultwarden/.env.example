# Vaultwarden (Bitwarden-compatible password manager). Copy to .env.
# Generate ADMIN_TOKEN:  openssl rand -base64 48
DOMAIN=https://vault.example.com
ADMIN_TOKEN=CHANGE_ME_openssl_rand_base64_48

# Turn signups off after you create your account.
SIGNUPS_ALLOWED=false

# Recommended: put Vaultwarden behind Cloudflare Access as well (see docs/security.md).
