# arr stack (VPN-isolated downloaders). Copy to .env.
# gluetun connects to ProtonVPN over WireGuard; paste the private key from your
# ProtonVPN WireGuard config (Account -> Downloads/WireGuard -> generate config).
PROTON_WG_PRIVATE_KEY=CHANGE_ME_wireguard_private_key

# The VPN provider/country and PUID/PGID are set in docker-compose.yml.
# If your host user isn't uid/gid 1000, adjust PUID/PGID there to match `id`.
